<script>
(function() {
  var sid = '{{ section.id }}';
  var variants = (typeof btPdVariants_ !== 'undefined') ? window['btPdVariants_' + sid] : [];
  var selectedOptions = [];

  /* ── Init selected options from active buttons ── */
  var optionGroups = document.querySelectorAll('#bt-pd-' + sid + ' .bt-pd-variants[data-option-index]');
  optionGroups.forEach(function(group) {
    var active = group.querySelector('.bt-pd-active');
    selectedOptions[parseInt(group.dataset.optionIndex)] = active ? active.dataset.value : null;
  });

  /* ── Find variant matching current selected options ── */
  function findVariant() {
    return variants.find(function(v) {
      return v.options.every(function(opt, i) {
        return !selectedOptions[i] || opt === selectedOptions[i];
      });
    }) || variants[0];
  }

  /* ── Update price display + variant hidden input ── */
  function updateVariant() {
    var v = findVariant();
    if (!v) return;
    var priceEl = document.getElementById('bt-pd-price-' + sid);
    var compareEl = document.getElementById('bt-pd-compare-' + sid);
    var saveEl = document.getElementById('bt-pd-save-' + sid);
    var variantInput = document.getElementById('bt-pd-variant-id-' + sid);
    var atcPrice = document.getElementById('bt-pd-atc-price-' + sid);
    var atcBtn = document.getElementById('bt-pd-atc-btn-' + sid);

    function money(cents) {
      return '€' + (cents / 100).toFixed(2).replace('.', ',');
    }

    if (priceEl) priceEl.textContent = money(v.price);
    if (atcPrice) atcPrice.textContent = money(v.price);
    if (variantInput) variantInput.value = v.id;
    if (atcBtn) atcBtn.disabled = !v.available;

    if (v.compare_at_price && v.compare_at_price > v.price) {
      if (compareEl) { compareEl.textContent = money(v.compare_at_price); compareEl.style.display = ''; }
      if (saveEl) {
        var pct = Math.round((v.compare_at_price - v.price) * 100 / v.compare_at_price);
        saveEl.textContent = 'SAVE ' + pct + '%';
        saveEl.style.display = '';
      }
    } else {
      if (compareEl) compareEl.style.display = 'none';
      if (saveEl) saveEl.style.display = 'none';
    }
  }

  /* ── Loop selling plan allocations ── */
  var allocations   = window['btPdAllocations_' + sid] || {};
  var sellingPlanInput = document.getElementById('bt-pd-selling-plan-' + sid);
  var subWrap       = document.getElementById('bt-pd-sub-wrap-' + sid);
  var onetimeBtn    = document.getElementById('bt-pd-onetime-btn-' + sid);
  var onetimeRow    = document.getElementById('bt-pd-onetime-row-' + sid);
  var onetimeVal    = document.getElementById('bt-pd-onetime-val-' + sid);
  var isSubscribe   = true; /* subscription active by default */

  function setSubscribeMode(subscribe) {
    isSubscribe = subscribe;
    var v = findVariant();
    var varAllocs = v ? (allocations[String(v.id)] || []) : [];

    if (subscribe && varAllocs[0]) {
      /* Subscribe mode */
      if (subWrap)  subWrap.classList.remove('bt-pd-onetime-active');
      if (sellingPlanInput) sellingPlanInput.value = varAllocs[0].id;
      if (atcPrice) atcPrice.textContent = money(varAllocs[0].per_delivery_price);
      if (onetimeBtn) onetimeBtn.innerHTML = 'buy one-time for <span id="bt-pd-onetime-val-' + sid + '">' + money(v ? v.price : 0) + '</span>';
    } else {
      /* One-time mode */
      if (subWrap)  subWrap.classList.add('bt-pd-onetime-active');
      if (sellingPlanInput) sellingPlanInput.value = '';
      if (atcPrice) atcPrice.textContent = money(v ? v.price : 0);
      if (onetimeBtn) onetimeBtn.innerHTML = 'switch to subscription';
    }
  }

  /* Update sub box content for current variant's allocation */
  function updateSubOption() {
    var v = findVariant();
    if (!v) return;

    var varAllocs = allocations[String(v.id)] || [];

    /* Update one-time price in link */
    var ovEl = document.getElementById('bt-pd-onetime-val-' + sid);
    if (ovEl) ovEl.textContent = money(v.price);

    if (varAllocs.length === 0) {
      /* No subscription for this variant — hide sub box, force one-time */
      if (subWrap)  subWrap.style.display = 'none';
      if (onetimeRow) onetimeRow.style.display = 'none';
      if (sellingPlanInput) sellingPlanInput.value = '';
      if (atcPrice) atcPrice.textContent = money(v.price);
      return;
    }

    if (subWrap)  subWrap.style.display = '';
    if (onetimeRow) onetimeRow.style.display = '';
    var alloc = varAllocs[0];

    /* Price per delivery */
    var priceEl = document.getElementById('bt-pd-sub-price-' + sid);
    if (priceEl) priceEl.textContent = money(alloc.per_delivery_price);

    /* Compare + save badge */
    var compareEl = document.getElementById('bt-pd-sub-compare-' + sid);
    var saveEl    = document.getElementById('bt-pd-sub-save-' + sid);
    if (alloc.compare_at_price && alloc.compare_at_price > alloc.per_delivery_price) {
      if (compareEl) { compareEl.textContent = money(alloc.compare_at_price); compareEl.style.display = ''; }
      if (saveEl) {
        var pct = Math.round((alloc.compare_at_price - alloc.per_delivery_price) * 100 / alloc.compare_at_price);
        saveEl.textContent = 'SAVE ' + pct + '%';
        saveEl.style.display = '';
      }
    } else {
      if (compareEl) compareEl.style.display = 'none';
      if (saveEl)    saveEl.style.display    = 'none';
    }

    /* Delivery interval */
    var detailEl = document.getElementById('bt-pd-sub-detail-' + sid);
    if (detailEl && alloc.options && alloc.options[0]) {
      detailEl.textContent = 'Delivered ' + alloc.options[0].value.toLowerCase();
    }

    /* Apply current mode (sub or one-time) */
    setSubscribeMode(isSubscribe);
  }

  /* One-time / subscribe toggle button */
  if (onetimeBtn) {
    onetimeBtn.addEventListener('click', function(e) {
      e.preventDefault();
      setSubscribeMode(!isSubscribe);
    });
  }

  /* Clicking the sub box when in one-time mode → re-activate subscribe */
  if (subWrap) {
    subWrap.addEventListener('click', function() {
      if (!isSubscribe) setSubscribeMode(true);
    });
  }

  /* ── Variant option button clicks ── */
  optionGroups.forEach(function(group) {
    group.querySelectorAll('.bt-pd-variant-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        group.querySelectorAll('.bt-pd-variant-btn').forEach(function(b) { b.classList.remove('bt-pd-active'); });
        this.classList.add('bt-pd-active');
        selectedOptions[parseInt(group.dataset.optionIndex)] = this.dataset.value;
        updateVariant();
        updateSubOption();
      });
    });
  });

  /* Run on load — subscription active by default */
  updateSubOption();

  /* ── Thumbnail gallery swap ── */
  var mainImg = document.getElementById('bt-pd-main-img-' + sid);
  var thumbs = document.querySelectorAll('#bt-pd-' + sid + ' .bt-pd-gallery__thumb');
  thumbs.forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      var src = this.getAttribute('data-src');
      if (src && mainImg) mainImg.src = src;
      thumbs.forEach(function(t) { t.classList.remove('bt-pd-active'); });
      this.classList.add('bt-pd-active');
    });
  });

  /* ── FAQ accordion ── */
  document.querySelectorAll('#bt-pd-' + sid + ' .bt-pd-faq__item').forEach(function(item) {
    item.querySelector('.bt-pd-faq__q').addEventListener('click', function() {
      var open = item.classList.contains('bt-pd-open');
      document.querySelectorAll('#bt-pd-' + sid + ' .bt-pd-faq__item').forEach(function(i) { i.classList.remove('bt-pd-open'); });
      if (!open) item.classList.add('bt-pd-open');
    });
  });

  /* ── Review carousel ── */
  var carousel = document.getElementById('bt-pd-carousel-' + sid);
  var prevBtn = document.getElementById('bt-pd-prev-' + sid);
  var nextBtn = document.getElementById('bt-pd-next-' + sid);
  if (carousel && prevBtn && nextBtn) {
    var current = 0;
    var cards = carousel.querySelectorAll('.bt-pd-review-card');
    function visible() { return window.innerWidth <= 768 ? 1 : 3; }
    function update() {
      var vis = visible();
      var max = Math.max(0, cards.length - vis);
      if (current > max) current = max;
      var w = carousel.parentElement.offsetWidth / vis;
      carousel.style.transform = 'translateX(-' + (current * w) + 'px)';
      cards.forEach(function(c) { c.style.minWidth = (w - 20) + 'px'; });
    }
    prevBtn.addEventListener('click', function() { if (current > 0) { current--; update(); } });
    nextBtn.addEventListener('click', function() { if (current < cards.length - visible()) { current++; update(); } });
    window.addEventListener('resize', update);
    update();
  }
})();
</script>

